# ============================================================
# X (Twitter) Advanced Scraper — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# --- Twitter API v2 (Bearer Token) ---
# Obtain from https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here

# --- Twitter API v2 (OAuth 1.0a — for user-context endpoints) ---
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# --- Scraper Settings ---
# Maximum tweets to fetch per query (default: 500)
MAX_TWEETS=500

# Request delay range in seconds (anti-rate-limit)
MIN_DELAY=1.5
MAX_DELAY=4.0

# Output format: csv | json | excel
OUTPUT_FORMAT=csv

# Output directory for scraped data
OUTPUT_DIR=./output

# --- Proxy Configuration (optional) ---
# HTTP_PROXY=http://user:pass@proxy:port
# HTTPS_PROXY=http://user:pass@proxy:port

# --- Browser Scraping (Playwright fallback) ---
# Set to true to enable headless browser scraping as fallback
USE_BROWSER_FALLBACK=false
HEADLESS=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/scraper.log
